generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BusinessType {
  corporation
  llc
  partnership
  sole_proprietorship
  investment_fund
  societies
  trust
  government
  dao
}

enum AccountPurpose {
  charitable_donations
  ecommerce_retail_payments
  investment_purposes
  other
  payments_to_friends_or_family_abroad
  payroll
  personal_or_living_expenses
  protect_wealth
  purchase_goods_and_services
  receive_payments_for_goods_and_services
  tax_optimization
  third_party_money_transmission
  treasury_management
}

enum SourceOfFunds {
  business_loans
  grants
  inter_company_funds
  investment_proceeds
  legal_settlement
  owners_capital
  pension_retirement
  sale_of_assets
  sales_of_goods_and_services
  tax_refund
  third_party_funds
  treasury_reserves
}

enum SourceOfWealth {
  business_dividends_or_profits
  investments
  asset_sales
  client_investor_contributions
  gambling
  charitable_contributions
  inheritance
  affiliate_or_royalty_income
}

enum DocType {
  aml_comfort_letter
  constitutional_document
  directors_registry
  cert_of_incumbency
  e_signature_certificate
  evidence_of_good_standing
  flow_of_funds
  formation_document
  marketing_materials
  other
  ownership_chart
  ownership_information
  proof_of_account_purpose
  proof_of_address
  proof_of_entity_name_change
  proof_of_nature_of_business
  proof_of_nature_of_business_license
  proof_of_nature_of_business_aml_policy
  proof_of_signatory_authority
  proof_of_source_of_funds
  proof_of_source_of_wealth
  proof_of_tax_identification
  registration_document
  shareholder_register
  evidence_of_directors_and_controllers
  tax_exempt_entity_confirmation
}

model User {
  id                 String  @id @default(uuid())
  clerkUserId        String  @unique @map("clerk_user_id")
  email              String  @unique
  oneMoneyCustomerId String? @unique @map("onemoney_customer_id")
  oneMoneyKybStatus  String? @map("onemoney_kyb_status")

  // Business details
  businessLegalName          String? @map("business_legal_name")
  businessDescription        String? @map("business_description")
  businessType               BusinessType? @map("business_type")
  businessIndustry           String? @map("business_industry")
  businessRegistrationNumber String? @map("business_registration_number")
  dateOfIncorporation        String? @map("date_of_incorporation")
  primaryWebsite             String? @map("primary_website")
  publiclyTraded             Boolean? @map("publicly_traded")

  // Tax
  taxId      String? @map("tax_id")
  taxType    String? @map("tax_type")
  taxCountry String? @map("tax_country")

  // Financial
  accountPurpose                  AccountPurpose?  @map("account_purpose")
  sourceOfFunds                   SourceOfFunds[] @map("source_of_funds")
  sourceOfWealth                  SourceOfWealth[] @map("source_of_wealth")
  estimatedAnnualRevenueUsd       String?  @map("estimated_annual_revenue_usd")
  expectedMonthlyFiatDeposits     String?  @map("expected_monthly_fiat_deposits")
  expectedMonthlyFiatWithdrawals  String?  @map("expected_monthly_fiat_withdrawals")

  // Registered address
  registeredAddressStreetLine1  String? @map("registered_address_street_line_1")
  registeredAddressStreetLine2  String? @map("registered_address_street_line_2")
  registeredAddressCity         String? @map("registered_address_city")
  registeredAddressState        String? @map("registered_address_state")
  registeredAddressCountry      String? @map("registered_address_country")
  registeredAddressSubdivision  String? @map("registered_address_subdivision")
  registeredAddressPostalCode   String? @map("registered_address_postal_code")

  // TOS
  signedAgreementId String? @map("signed_agreement_id")

  // Relations
  associatedPersons AssociatedPerson[]
  documents         BusinessDocument[]
  activityLogs      ActivityLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model AssociatedPerson {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal info
  firstName          String  @map("first_name")
  middleName         String? @map("middle_name")
  lastName           String  @map("last_name")
  email              String
  birthDate          String  @map("birth_date")
  primaryNationality String  @map("primary_nationality")

  // OneMoney mapping
  oneMoneyAssociatedPersonId String? @unique @map("onemoney_associated_person_id")

  // Roles & ownership
  hasOwnership        Boolean  @map("has_ownership")
  ownershipPercentage Float?   @map("ownership_percentage")
  hasControl          Boolean  @map("has_control")
  isSigner            Boolean  @map("is_signer")
  isDirector          Boolean  @map("is_director")

  // Tax
  countryOfTax String @map("country_of_tax")
  taxType      String @map("tax_type")
  taxId        String @map("tax_id")

  // POA
  poa     String? @map("poa")
  poaType String? @map("poa_type")

  // Residential address
  residentialAddressStreetLine1 String  @map("residential_address_street_line_1")
  residentialAddressStreetLine2 String? @map("residential_address_street_line_2")
  residentialAddressCity        String  @map("residential_address_city")
  residentialAddressState       String  @map("residential_address_state")
  residentialAddressCountry     String  @map("residential_address_country")
  residentialAddressSubdivision String? @map("residential_address_subdivision")
  residentialAddressPostalCode  String? @map("residential_address_postal_code")

  // Identifying document
  docType                   String? @map("doc_type")
  docIssuingCountry         String? @map("doc_issuing_country")
  docNationalIdentityNumber String? @map("doc_national_identity_number")
  docImageFrontUrl          String? @map("doc_image_front_url")
  docImageBackUrl           String? @map("doc_image_back_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("associated_persons")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  category  String
  detail    String?
  metadata  Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, category])
  @@map("activity_logs")
}

model BusinessDocument {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  docType     DocType  @map("doc_type")
  fileUrl     String  @map("file_url")
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("business_documents")
}
